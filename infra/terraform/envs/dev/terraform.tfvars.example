project_name = "peakorder-insight"
environment  = "dev"
aws_region   = "ap-northeast-2"

# Bucket names must be globally unique. Leave these as null to use generated names.
raw_bucket_name       = null
lakehouse_bucket_name = null

# EMR Serverless defaults for small portfolio-friendly runs.
emr_release_label          = "emr-7.2.0"
emr_maximum_cpu            = "8 vCPU"
emr_maximum_memory         = "24 GB"
emr_maximum_disk           = "100 GB"
emr_idle_timeout_minutes   = 15
