AWS_REGION=ap-northeast-2
PROJECT_NAME=peakorder-insight
ENVIRONMENT=dev

RAW_BUCKET=
LAKEHOUSE_BUCKET=
ORDER_EVENTS_STREAM_NAME=
PAIMON_WAREHOUSE=s3://your-lakehouse-bucket/paimon
DASHBOARD_EXPORT_PREFIX=s3://your-lakehouse-bucket/exports/dashboard
PEAK_PRESSURE_THRESHOLD=2.5
PEAK_MIN_ORDERS=20
BASE_ORDERS_PER_HOUR=5000
PEAK_MULTIPLIER=10
LIVE_DASHBOARD_PORT=8010

# Airflow orchestration
PEAKORDER_REPO_ROOT=/opt/airflow/PeakOrder_Insight
EMR_SERVERLESS_APPLICATION_ID=
PIPELINE_ROLE_ARN=
GLUE_DATABASE_NAME=peakorder_insight_dev
PAIMON_SPARK_PACKAGE=org.apache.paimon:paimon-spark-3.5:1.0.1
